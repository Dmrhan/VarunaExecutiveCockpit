# ─── DB Driver ─────────────────────────────────────────────────────────────────
# "sqlite" for local dev/test (default)
# "mssql"  for staging/production
DB_DRIVER=sqlite

# ─── SQLite ─────────────────────────────────────────────────────────────────────
# Path is relative to varuna-bff root; default: varuna.db (auto-created)
# SQLITE_PATH=./varuna.db

# ─── MS SQL Server ──────────────────────────────────────────────────────────────
# Required when DB_DRIVER=mssql
MSSQL_SERVER=localhost
MSSQL_DATABASE=VarunaDB
MSSQL_USER=sa
MSSQL_PASSWORD=your_password_here
MSSQL_PORT=1433

# Set to false for self-signed / dev certs; keep true for production
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# ─── BFF Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
